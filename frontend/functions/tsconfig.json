{
  "compilerOptions": {
    "lib": [
      "ES2022",
      "DOM"
    ],
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "types": [
      "@cloudflare/workers-types"
    ]
  }
}