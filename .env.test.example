# Copy to .env.test and fill in values.
# The test suite loads this file automatically (dotenvy::from_filename(".env.test")).

# ── Test Postgres (docker-compose.test.yml, port 5433) ─────────────────────
TEST_DATABASE_URL=postgres://dal_test:test@localhost:5433/dal_test

# ── Test LocalStack S3-compatible + SQS (docker-compose.test.yml, port 4567) ──────────
TEST_STORAGE_ENDPOINT_URL=http://localhost:4567
TEST_STORAGE_REGION=eu-central-1
TEST_SQS_ENDPOINT_URL=http://localhost:4567
TEST_SQS_QUEUE_URL=http://sqs.eu-central-1.localhost.localstack.cloud:4567/000000000000/dal-jobs-test.fifo

# ── Cognito-local (run separately: npx --yes cognito-local) ─────────────────
# Leave unset to skip auth tests that need Cognito.
# TEST_COGNITO_ENDPOINT_URL=http://localhost:9229
# TEST_COGNITO_POOL_ID=eu-central-1_testpool
# TEST_COGNITO_CLIENT_ID=testclientid

# ── AWS fake creds (used by LocalStack — do NOT use real keys here) ─────────
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=eu-central-1
