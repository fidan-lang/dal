# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Cognito ───────────────────────────────────────────────────────────────────
# The User Pool ID (e.g. eu-central-1_AbC123def)
DAL_COGNITO_USER_POOL_ID=eu-central-1_XXXXXXXXX
# The App Client ID (no secret — public client, server-side auth flow)
DAL_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── S3 ───────────────────────────────────────────────────────────────────────
DAL_S3_BUCKET=dal-packages-prod
# Override endpoint for local dev (LocalStack or MinIO). Leave empty in prod.
DAL_S3_ENDPOINT_URL=

# ── SQS ──────────────────────────────────────────────────────────────────────
DAL_SQS_QUEUE_URL=https://sqs.eu-central-1.amazonaws.com/000000000000/dal-jobs.fifo
# Override endpoint for local dev (LocalStack). Leave empty in prod.
DAL_SQS_ENDPOINT_URL=
# Periodic worker cleanup for never-verified accounts (defaults shown).
DAL_UNVERIFIED_ACCOUNT_RETENTION_DAYS=7
DAL_ACCOUNT_CLEANUP_INTERVAL_SECS=21600
DAL_ACCOUNT_CLEANUP_BATCH_SIZE=100

# ── Database (PostgreSQL on Neon) ──────────────────────────────────────────────
DATABASE_URL=postgres://dal:password@localhost:5432/dal

# ── Mailjet ───────────────────────────────────────────────────────────────────
MAILJET_API_KEY=your_mailjet_api_key
MAILJET_SECRET_KEY=your_mailjet_secret_key
MAILJET_FROM_EMAIL=noreply@dal.fidan.dev
MAILJET_FROM_NAME=Dal Package Registry

# ── Server ────────────────────────────────────────────────────────────────────
# Host:port for the Axum server to bind
DAL_LISTEN_ADDR=0.0.0.0:8080
# Public base URL (used in email links, presigned URL redirects, etc.)
DAL_BASE_URL=https://dal.fidan.dev

# ── Limits ────────────────────────────────────────────────────────────────────
# Maximum package archive size in bytes (default: 52428800 = 50 MiB)
DAL_MAX_UPLOAD_BYTES=52428800
# Maximum package version name length
DAL_MAX_VERSION_LENGTH=64

# ── Dev ───────────────────────────────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"  (RUST_LOG also accepted)
DAL_LOG_LEVEL=info
# Set to "true" to pretty-print JSON logs (dev) vs compact (prod)
DAL_LOG_PRETTY=true
